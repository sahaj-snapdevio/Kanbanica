# ─────────────────────────────────────────────────────────────────────────────
# .env.test — environment for the DB-backed INTEGRATION test suite
# (`pnpm test:integration` / `pnpm test:all`).
#
# Copy this file to `.env.test` and fill in the values. `.env.test` is
# gitignored (real secrets live ONLY on your machine); this `.example` is the
# committed template so the file can be recreated.
#
# These are TEST values — never point DATABASE_URL at a real database. The
# integration harness spins up a throwaway `postgres:18` container on the port
# below, applies the full migration chain, runs the tests, then destroys it.
# The non-DB secrets just need to be NON-EMPTY so `lib/env` validates; the
# integration tests don't make real OAuth/Pusher/Polar/EmailIt calls.
# ─────────────────────────────────────────────────────────────────────────────

# MUST match the port scripts/test-integration.sh starts the throwaway PG on.
DATABASE_URL=postgres://krovatest:krovatest@localhost:55434/krovatest

# Any 32+ char string. Also the AES key the storage-backend seed encrypts with.
APP_SECRET=test-app-secret-at-least-32-characters-long

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=test

# Dummy — integration tests don't perform real OAuth / email / realtime.
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
EMAILIT_API_KEY=test-emailit-api-key
EMAILIT_FROM=Krova Test <test@example.com>
# Pusher/Soketi — for tests that exercise real-time. Point at a dev Soketi
# (self-hosted: set HOST + PORT, leave CLUSTER empty). Dummy values are fine
# for the DB-only integration tests.
PUSHER_APP_ID=dev-krova-id
PUSHER_KEY=dev-krova-key
PUSHER_SECRET=your-soketi-app-secret
PUSHER_HOST=dev-soketi.example.com
PUSHER_PORT=443

# ── Test S3 sandbox (iDrive E2) ──────────────────────────────────────────────
# Real S3-compatible sandbox bucket used by the storage integration tests. The
# harness seeds a `storage_backends` row from these (the app stores backend
# creds in the DB, AES-encrypted with APP_SECRET — NOT in env — so these are
# TEST_*-prefixed and consumed only by the test seed, not by lib/env).
# Use a THROWAWAY/sandbox bucket; objects are created + deleted by tests.
TEST_S3_ENDPOINT=https://s3.us-west-2.idrivee2.com
TEST_S3_REGION=us-west-2
TEST_S3_BUCKET=your-sandbox-bucket
TEST_S3_ACCESS_KEY_ID=your-test-access-key-id
TEST_S3_SECRET_ACCESS_KEY=your-test-secret-access-key
