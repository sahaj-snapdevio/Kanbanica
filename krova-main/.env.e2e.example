# ─────────────────────────────────────────────────────────────────────────────
# .env.e2e — environment for the ON-HOST cube-lifecycle E2E (`pnpm test:e2e`).
#
# Copy to `.env.e2e` and fill in. `.env.e2e` is gitignored (real creds + the
# dev-server SSH key path live ONLY on your machine); this `.example` is the
# committed template.
#
# Unlike the unit/integration tiers, this E2E drives the REAL setup-phase +
# cube-lifecycle handlers against a REAL KVM host (a throwaway dev server),
# boots a cube from the REAL Krova rootfs, and runs in-guest tests. It needs:
#   • a throwaway postgres (the harness starts one on the port below)
#   • SSH access to a dedicated dev/test KVM host (NOT production)
#   • an S3 sandbox bucket (snapshot/backup legs)
# Email + Cloudflare + Polar are NOT exercised (CF is skipped in E2E mode).
# ─────────────────────────────────────────────────────────────────────────────

# Throwaway PG — MUST match scripts/test-e2e.sh's port (55435).
DATABASE_URL=postgres://krovae2e:krovae2e@localhost:55435/krovae2e

# 32+ chars. Also the AES key for the seeded SSH key + storage-backend creds.
APP_SECRET=e2e-app-secret-at-least-32-characters-long-xx
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=test

# Dummy — the E2E performs no real OAuth / email.
GOOGLE_CLIENT_ID=e2e-google-client-id
GOOGLE_CLIENT_SECRET=e2e-google-client-secret
EMAILIT_API_KEY=e2e-emailit-api-key
EMAILIT_FROM=Krova E2E <e2e@example.com>

# Pusher/Soketi — JobLogger emits job.log events (best-effort; dummy is fine).
PUSHER_APP_ID=dev-krova-id
PUSHER_KEY=dev-krova-key
PUSHER_SECRET=your-soketi-app-secret
PUSHER_HOST=dev-soketi.example.com
PUSHER_PORT=443

# Skip ONLY the Cloudflare origin-DNS sub-step of the install phase (test-only).
KROVA_E2E_SKIP_CLOUDFLARE=true

# ── The dev/test KVM host the E2E sets up + boots a cube on ───────────────────
# MUST be a throwaway box with /dev/kvm. The bootstrap phase hardens its sshd to
# port 2822 + pushes the platform key; the reboot phase reboots it. NEVER point
# this at a production server.
E2E_SSH_HOST=203.0.113.10
E2E_SSH_PORT=22
E2E_SSH_USER=root
# Path to the private key that already has access to E2E_SSH_HOST (used as BOTH
# the bootstrap initial creds AND the platform key pushed for port 2822).
E2E_HOST_KEY_PATH=~/.ssh/krova_devtest
# Where the Krova kernel+rootfs were built on the host (pull_images placement).
E2E_HOST_IMAGES_DIR=/root/krova-build/out
# A DNS label for the seeded server (derived hostnames hang off it). Keep unique.
E2E_SERVER_HOSTNAME=e2e-devtest

# ── S3 sandbox (iDrive E2 / any S3-compatible) — snapshot + backup legs ───────
# THROWAWAY bucket; the E2E writes + deletes a restic repo + a .cube backup.
TEST_S3_ENDPOINT=https://s3.us-west-2.idrivee2.com
TEST_S3_REGION=us-west-2
TEST_S3_BUCKET=your-sandbox-bucket
TEST_S3_ACCESS_KEY_ID=your-test-access-key-id
TEST_S3_SECRET_ACCESS_KEY=your-test-secret-access-key
