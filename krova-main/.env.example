# PostgreSQL connection string
# For development: run `pnpm db:local` in a separate terminal to start an
# embedded Postgres server that reads user/password/port/database from this
# URL. Data is persisted to `.pgdata/`.
DATABASE_URL=postgres://postgres:password@localhost:54329/krova

# App secret — used for session signing, token generation, and AES-256 encryption at rest
APP_SECRET=your-secret-key-at-least-32-characters

# The public URL of the app (used for OAuth redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth credentials (required)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# EmailIt — transactional email + marketing contact sync (https://emailit.com/docs/api-reference/)
# API key + From are required. From must be on a domain verified in the EmailIt workspace.
EMAILIT_API_KEY=your-emailit-api-key
EMAILIT_FROM=Krova <noreply@krova.cloud>
# Webhook signing secret (whsec_…) — EmailIt dashboard → Webhooks → Webhook secret.
# Optional: when unset, the webhook route rejects all deliveries (503).
EMAILIT_WEBHOOK_SECRET=
# Marketing audience id (aud_xxx) that synced contacts join.
# Optional: when unset, contact sync is inert (transactional email + webhooks still work).
EMAILIT_AUDIENCE_ID=

# Pusher / Soketi (real-time WebSocket — optional, live updates disabled if not set)
# For Soketi (self-hosted): set HOST + PORT, leave CLUSTER empty
# For Pusher cloud: set CLUSTER, leave HOST + PORT empty
PUSHER_APP_ID=app-id
PUSHER_KEY=app-key
PUSHER_SECRET=app-secret
PUSHER_HOST=socket.example.com
PUSHER_PORT=443
PUSHER_CLUSTER=any

# Cloudflare for SaaS — custom domain routing (optional; app boots without them).
# See docs/superpowers/specs/2026-05-16-cloudflare-for-saas-design.md.
# `pnpm cloudflare:check` validates presence + correctness before integration code runs.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
# Wildcard Origin CA cert + key (PEM) — paste with literal newlines or \n escapes.
CLOUDFLARE_ORIGIN_CERT=
CLOUDFLARE_ORIGIN_KEY=

# Polar payments — credit top-up + paid-plan subscriptions (optional; app
# boots without them, payments are inert until set).
# POLAR_SERVER selects the sandbox vs production Polar API.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
# Polar product ids (credit top-up, subscription products per plan) and the
# overage meter id are NOT env-managed — they live in the DB:
#   • plans.polarProductId           → managed via Orbit → Plans (provision button)
#   • platform_settings.polarCreditProductId   → Orbit → Platform Settings
#   • platform_settings.polarOverageMeterId    → Orbit → Platform Settings
# The processing-fee gross-up (`platform_settings.paymentFeePercent` +
# `paymentFeeFlatUsd`) is applied automatically when a plan is provisioned in
# Polar, so the Polar product is created at the correct grossed-up price.

# Google Tag Manager container id (e.g. GTM-XXXXXXX), wired into the
# `@analytics/google-tag-manager` plugin via the AnalyticsProvider in the
# root layout. Ships to the browser as a `NEXT_PUBLIC_*` var. Operators
# configure GA4 + any other vendor tags inside the GTM workspace.
# Optional: when unset, page views + custom events are silent no-ops.
NEXT_PUBLIC_GTM_CONTAINER_ID=

# Build output dir for `pnpm build:images` (optional — defaults to setup/images/images).
# Bind-mounted host↔worker container in production.
KROVA_BUILD_OUTDIR=

# Non-sensitive platform config is in config/platform.ts (edit and redeploy).
# Storage backends (S3-compatible buckets) are managed via Orbit → Storage.
# Per-backend access key + secret are AES-256-GCM encrypted in the DB using
# APP_SECRET — no S3 env vars are needed here.
