# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/saas_starter

# Better Auth — must be 32+ characters
APP_SECRET=change-me-to-a-random-32-char-secret!!

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="My SaaS App <no-reply@example.com>"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# S3-compatible storage (Cloudflare R2, AWS S3, MinIO, Backblaze B2 …)
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: public CDN URL for the bucket (leave blank to use presigned URLs)
S3_PUBLIC_URL=
