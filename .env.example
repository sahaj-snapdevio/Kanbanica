# ── Required ──────────────────────────────────────────────────────────────────
# DATABASE_URL:
#   • Local dev (pnpm db:local):  postgresql://krova:krova@localhost:54329/krova
#   • Docker Compose:             postgresql://kanbanica:<password>@postgres:5432/kanbanica
DATABASE_URL=postgresql://krova:krova@localhost:54329/krova
# APP_SECRET: 32+ random chars. Generate with:  openssl rand -hex 32
APP_SECRET=replace-with-at-least-32-random-characters
# NEXT_PUBLIC_APP_URL: the public URL users hit. In production use your real
# https domain, e.g. https://tasks.yourcompany.com (inlined at build time).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Authentication providers ──────────────────────────────────────────────────
# In PRODUCTION you must configure AT LEAST ONE of: full SMTP (below) OR Google
# OAuth. Otherwise users cannot log in and the app refuses to start.
#
# Email (SMTP) — optional in local dev (magic links are logged to the console).
# Works with any SMTP provider: Mailtrap, SendGrid, Postmark, AWS SES, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Google OAuth — alternative login that works without SMTP.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Docker Compose only ───────────────────────────────────────────────────────
# Used by docker-compose.yml to provision the bundled Postgres. Match these with
# the DATABASE_URL above (host = the "postgres" service, port 5432).
# POSTGRES_USER=kanbanica
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=kanbanica
# APP_PORT=3000

# ── Email Webhook ──────────────────────────────────────────────────────────────
# Optional. Set this to receive delivery events from your SMTP provider.
# Accepts Authorization: Bearer <secret> or x-webhook-secret header.
# EMAIL_WEBHOOK_SECRET=

# ── File Storage (files-sdk) ──────────────────────────────────────────────────
# "local" stores files in ./uploads/ and serves via /api/files (default).
#   In Docker, mount a volume at /app/uploads (docker-compose.yml does this) or
#   uploads are lost on redeploy.
# "s3" or "r2" uses cloud object storage — set the S3_* credentials below.
STORAGE_DRIVER=local

# S3 / R2 credentials (only needed when STORAGE_DRIVER=s3 or r2)
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com   # R2/MinIO only; omit for AWS S3
# S3_REGION=auto
# S3_BUCKET=kanbanica
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:your-email@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_key_here

# ── Branding (optional) ───────────────────────────────────────────────────────
# Override the public support email / marketing domain shown in the UI without
# editing code. Defaults live in config/platform.ts.
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourcompany.com
# NEXT_PUBLIC_MARKETING_DOMAIN=yourcompany.com