DATABASE_URL=postgresql://krova:krova@localhost:54329/krova
APP_SECRET=replace-with-at-least-32-random-characters
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Optional in local development. Without these, email sends are logged by the worker.
# Works with any SMTP provider: Mailtrap, SendGrid, Postmark, AWS SES, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ── Email Webhook ──────────────────────────────────────────────────────────────
# Optional. Set this to receive delivery events from your SMTP provider.
# Accepts Authorization: Bearer <secret> or x-webhook-secret header.
# EMAIL_WEBHOOK_SECRET=

# ── File Storage (files-sdk) ──────────────────────────────────────────────────
# "local" stores files in ./uploads/ and serves via /api/files (dev default)
# "s3" or "r2" uses cloud storage — add credentials and update lib/storage.ts
STORAGE_DRIVER=local

# S3 / R2 credentials (only needed when STORAGE_DRIVER=s3 or r2)
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=kanbanica
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
